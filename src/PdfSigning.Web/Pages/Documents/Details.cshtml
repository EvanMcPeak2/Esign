@page "/Documents/{id:guid}"
@using System.Text.Json
@model PdfSigning.Web.Pages.Documents.DetailsModel
@{
    ViewData["Title"] = "Document details";
}

<div class="row align-items-center mb-4">
    <div class="col-lg-8">
        <span class="badge text-bg-dark mb-2">Database view</span>
        <h1 class="display-6 fw-semibold mb-2">@Model.Document?.Title</h1>
        <p class="text-body-secondary mb-0">This page shows exactly what was saved in SQL Server for the uploaded PDF.</p>
    </div>
    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
        <a class="btn btn-outline-secondary" href="/Documents">Back to upload</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info" role="alert">@Model.StatusMessage</div>
}

@if (Model.Document is null)
{
    <div class="alert alert-warning">Document not found.</div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="feature-card rounded-4 p-4 h-100">
                <h2 class="h4 mb-2">PDF preview</h2>
                <p class="text-body-secondary mb-3">Click directly on the page to copy coordinates into the signature field form on the right.</p>

                <dl class="row mb-3 small">
                    <dt class="col-sm-4">Document ID</dt>
                    <dd class="col-sm-8"><code>@Model.Document.Id</code></dd>

                    <dt class="col-sm-4">Owner user ID</dt>
                    <dd class="col-sm-8"><code>@Model.Document.OwnerUserId</code></dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@Model.Document.Status</dd>

                    <dt class="col-sm-4">Original file</dt>
                    <dd class="col-sm-8">@Model.Document.OriginalFileName</dd>
                </dl>

                @if (!string.IsNullOrWhiteSpace(Model.Document.StorageKey))
                {
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <a class="btn btn-primary" href="/@Model.Document.StorageKey" target="_blank" rel="noopener">Open PDF in new tab</a>
                        @if (Model.Document.Status == PdfSigning.Web.Models.Documents.DocumentStatus.Draft && Model.Document.SignatureFields.Count > 0)
                        {
                            <form method="post" asp-page-handler="MarkReady" class="d-inline">
                                <button type="submit" class="btn btn-success">Mark ready for signing</button>
                            </form>
                        }
                    </div>

                    <div id="pdfPreviewShell"
                         class="pdf-preview-shell"
                         data-pdf-url="/@Model.Document.StorageKey"
                         data-fields='@Html.Raw(JsonSerializer.Serialize(Model.Document.SignatureFields.Select(field => new {
                             label = field.Label,
                             pageNumber = field.PageNumber,
                             x = field.X,
                             y = field.Y,
                             width = field.Width,
                             height = field.Height,
                             isRequired = field.IsRequired
                         })))'
                         data-current-page="@Model.AddField.PageNumber">
                        <canvas id="pdfPreviewCanvas" class="pdf-preview-canvas"></canvas>
                        <div id="pdfPreviewOverlay" class="pdf-preview-overlay" aria-hidden="true"></div>
                    </div>
                    <div id="pdfPreviewStatus" class="small text-body-secondary mt-2">Loading preview…</div>
                }
            </div>
        </div>
        <div class="col-lg-5">
            <div class="status-panel rounded-4 p-4 h-100">
                <h2 class="h4 mb-3">Signature fields</h2>

                <form method="post" asp-page-handler="AddField" class="mb-4">
                    <div class="row g-2">
                        <div class="col-12">
                            <label asp-for="AddField.Label" class="form-label">Label</label>
                            <input asp-for="AddField.Label" class="form-control" />
                        </div>
                        <div class="col-4">
                            <label asp-for="AddField.PageNumber" class="form-label">Page</label>
                            <input asp-for="AddField.PageNumber" class="form-control" type="number" min="1" />
                        </div>
                        <div class="col-4">
                            <label asp-for="AddField.X" class="form-label">X</label>
                            <input asp-for="AddField.X" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-4">
                            <label asp-for="AddField.Y" class="form-label">Y</label>
                            <input asp-for="AddField.Y" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-6">
                            <label asp-for="AddField.Width" class="form-label">Width</label>
                            <input asp-for="AddField.Width" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-6">
                            <label asp-for="AddField.Height" class="form-label">Height</label>
                            <input asp-for="AddField.Height" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-12 form-check mt-2 ms-2">
                            <input asp-for="AddField.IsRequired" class="form-check-input" />
                            <label asp-for="AddField.IsRequired" class="form-check-label">Required</label>
                        </div>
                        <div class="col-12 mt-2">
                            <button type="submit" class="btn btn-primary">Add field</button>
                        </div>
                    </div>
                </form>

                @if (Model.Document.SignatureFields.Count == 0)
                {
                    <p class="text-body-secondary mb-0">No signature fields are stored for this document yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Label</th>
                                    <th>Page</th>
                                    <th>Position</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var field in Model.Document.SignatureFields)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@field.Label</div>
                                            <div class="small text-body-secondary">@(field.IsRequired ? "Required" : "Optional")</div>
                                        </td>
                                        <td>@field.PageNumber</td>
                                        <td>
                                            <div class="small">X @field.X, Y @field.Y</div>
                                            <div class="small">W @field.Width, H @field.Height</div>
                                        </td>
                                        <td class="text-end">
                                            <form method="post" asp-page-handler="DeleteField" asp-route-signatureFieldId="@field.Id" onsubmit="return confirm('Delete this field?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@section Scripts {
    <script type="module" src="~/js/document-preview.js" asp-append-version="true"></script>
}

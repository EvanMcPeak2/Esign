@page "{id:guid}"
@model PdfSigning.Web.Pages.Documents.DetailsModel
@{
    ViewData["Title"] = "Document details";
}

<div class="row align-items-center mb-4">
    <div class="col-lg-8">
        <span class="badge text-bg-dark mb-2">Database view</span>
        <h1 class="display-6 fw-semibold mb-2">@Model.Document?.Title</h1>
        <p class="text-body-secondary mb-0">This page shows exactly what was saved in SQL Server for the uploaded PDF.</p>
    </div>
    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
        <a class="btn btn-outline-secondary" href="/Documents">Back to upload</a>
    </div>
</div>

@if (Model.Document is null)
{
    <div class="alert alert-warning">Document not found.</div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="feature-card rounded-4 p-4 h-100">
                <h2 class="h4 mb-3">Stored PDF</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Document ID</dt>
                    <dd class="col-sm-8"><code>@Model.Document.Id</code></dd>

                    <dt class="col-sm-4">Owner user ID</dt>
                    <dd class="col-sm-8"><code>@Model.Document.OwnerUserId</code></dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@Model.Document.Status</dd>

                    <dt class="col-sm-4">Original file</dt>
                    <dd class="col-sm-8">@Model.Document.OriginalFileName</dd>

                    <dt class="col-sm-4">Storage key</dt>
                    <dd class="col-sm-8"><code>@Model.Document.StorageKey</code></dd>
                </dl>

                @if (!string.IsNullOrWhiteSpace(Model.Document.StorageKey))
                {
                    <div class="mt-3">
                        <a class="btn btn-primary" href="/@Model.Document.StorageKey" target="_blank" rel="noopener">Open uploaded PDF</a>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-5">
            <div class="status-panel rounded-4 p-4 h-100">
                <h2 class="h4 mb-3">Signature fields</h2>
                @if (Model.Document.SignatureFields.Count == 0)
                {
                    <p class="text-body-secondary mb-0">No signature fields are stored for this document yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Label</th>
                                    <th>Page</th>
                                    <th>Position</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var field in Model.Document.SignatureFields)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@field.Label</div>
                                            <div class="small text-body-secondary">@(field.IsRequired ? "Required" : "Optional")</div>
                                        </td>
                                        <td>@field.PageNumber</td>
                                        <td>
                                            <div class="small">X @field.X, Y @field.Y</div>
                                            <div class="small">W @field.Width, H @field.Height</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

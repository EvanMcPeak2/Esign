@page "/Documents/Details/{id:guid}"
@using System.Text.Json
@model PdfSigning.Web.Pages.Documents.DetailsModel
@{
    ViewData["Title"] = "Document details";
    var canMarkReady = Model.Document is not null
        && Model.Document.Status == PdfSigning.Web.Models.Documents.DocumentStatus.Draft
        && Model.Document.SignatureFields.Count > 0;
}

<div class="document-hero rounded-4 p-4 p-lg-5 mb-4">
    <div class="row g-4 align-items-start">
        <div class="col-lg-8">
            <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="badge text-bg-dark">Document workspace</span>
                <span class="badge rounded-pill text-bg-secondary">@Model.Document?.Status</span>
                <span class="badge rounded-pill text-bg-light text-dark">@Model.Document?.SignatureFields.Count field(s)</span>
            </div>

            <h1 class="display-6 fw-semibold mb-2">@Model.Document?.Title</h1>
            <p class="text-body-secondary mb-0">
                Preview the PDF, place signature fields, and keep the editor focused on the parts you actually need.
            </p>
        </div>

        <div class="col-lg-4">
            <div class="workspace-actions d-grid gap-2">
                <a class="btn btn-outline-secondary" href="/Documents">Back to upload</a>

                @if (!string.IsNullOrWhiteSpace(Model.Document?.StorageKey))
                {
                    <a class="btn btn-primary" href="@Url.Page("/Documents/Pdf", new { id = Model.Document.Id })" target="_blank" rel="noopener">Open PDF in new tab</a>
                }

                <div id="markReadyContainer" class="@(canMarkReady ? string.Empty : "d-none")">
                    <form method="post" asp-page-handler="MarkReady" class="d-grid">
                        <button type="submit" class="btn btn-success">Mark ready for signing</button>
                    </form>
                </div>

                <div class="section-card rounded-4 p-3 p-lg-4 mt-3">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                        <h3 class="h6 mb-0 text-uppercase text-body-secondary letter-spaced">Send secure link</h3>
                        <span class="small text-body-secondary">No login required for the recipient.</span>
                    </div>

                    <form method="post" asp-page-handler="CreateSigningLink" class="d-grid gap-3">
                        <div class="app-field-group">
                            <label asp-for="SigningRecipientEmail" class="form-label">Recipient email</label>
                            <input asp-for="SigningRecipientEmail"
                                   class="form-control"
                                   placeholder="recipient@example.com"
                                   autocomplete="email"
                                   inputmode="email"
                                   spellcheck="false" />
                            <div id="recipientEmailHelp" class="form-text">This address is used to verify the signer before the document opens.</div>
                        </div>
                        <button type="submit" class="btn btn-outline-primary">Create secure signing link</button>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.GeneratedSigningLink))
                    {
                        <div class="alert alert-success mt-3 mb-0" role="alert">
                            <div class="fw-semibold mb-1">Secure link ready</div>
                            <div class="small mb-2">Expires @Model.GeneratedSigningLinkExpiresAtUtc?.ToLocalTime().ToString("g")</div>
                            <div class="input-group">
                                <input class="form-control" value="@Model.GeneratedSigningLink" readonly />
                                <a class="btn btn-outline-secondary" href="@Model.GeneratedSigningLink" target="_blank" rel="noopener">Open</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info" role="alert">@Model.StatusMessage</div>
}

@if (Model.Document is null)
{
    <div class="alert alert-warning">Document not found.</div>
}
else
{
    <div class="row g-4 align-items-start">
        <div class="col-lg-7">
            <div class="feature-card rounded-4 p-4 h-100">
                <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-3">
                    <div>
                        <h2 class="h4 mb-1">PDF preview</h2>
                        <p class="text-body-secondary mb-0">Click and drag on the page to position a signature field.</p>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Document.StorageKey))
                {
                    <div id="pdfPreviewShell"
                         class="pdf-preview-shell"
                         data-pdf-url="@Url.Page("/Documents/Pdf", new { id = Model.Document.Id })"
                         data-document-id="@Model.Document.Id"
                         data-document-status="@Model.Document.Status"
                         data-fields='@Html.Raw(JsonSerializer.Serialize(Model.Document.SignatureFields.Select(field => new {
                             id = field.Id,
                             label = field.Label,
                             pageNumber = field.PageNumber,
                             x = field.X,
                             y = field.Y,
                             width = field.Width,
                             height = field.Height,
                             isRequired = field.IsRequired
                         })))'
                         data-current-page="@Model.AddField.PageNumber">
                        <canvas id="pdfPreviewCanvas" class="pdf-preview-canvas"></canvas>
                        <div id="pdfPreviewOverlay" class="pdf-preview-overlay" aria-hidden="true"></div>
                        <div id="pdfPreviewDraft" class="pdf-preview-draft" aria-hidden="true"></div>
                    </div>
                    <div id="pdfPreviewStatus" class="small text-body-secondary mt-2">Loading preview…</div>
                }
                else
                {
                    <div class="preview-placeholder rounded-4 p-4 text-center text-body-secondary">
                        The uploaded PDF is missing a storage path, so the inline preview cannot load.
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-5">
            <div class="status-panel rounded-4 p-4 h-100">
                <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-4">
                    <div>
                        <h2 class="h4 mb-1">Signature fields</h2>
                        <p class="text-body-secondary mb-0">Add a label, toggle required, and draw the field on the PDF.</p>
                    </div>
                    <span class="badge rounded-pill text-bg-light text-dark">Live sync</span>
                </div>

                <div class="section-card rounded-4 p-3 p-lg-4 mb-4">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                        <h3 class="h6 mb-0 text-uppercase text-body-secondary letter-spaced">Create a field</h3>
                        <span class="small text-body-secondary">Use the preview to fill coordinates automatically.</span>
                    </div>

                    <form method="post" asp-page-handler="AddField" id="addFieldForm">
                        <input asp-for="AddField.PageNumber" type="hidden" />
                        <input asp-for="AddField.X" type="hidden" />
                        <input asp-for="AddField.Y" type="hidden" />
                        <input asp-for="AddField.Width" type="hidden" />
                        <input asp-for="AddField.Height" type="hidden" />

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="AddField.Label" class="form-label">Label</label>
                                <input asp-for="AddField.Label" class="form-control" />
                            </div>
                            <div class="col-12 d-flex align-items-center justify-content-between gap-3 field-toggle-row">
                                <div class="form-check m-0">
                                    <input asp-for="AddField.IsRequired" class="form-check-input" />
                                    <label asp-for="AddField.IsRequired" class="form-check-label">Required</label>
                                </div>
                                <span class="small text-body-secondary">Field location is captured from the preview.</span>
                            </div>
                            <div class="col-12 d-grid gap-2 mt-2">
                                <button type="submit" class="btn btn-primary btn-lg">Add field</button>
                                <div class="small text-body-secondary">The field is saved to the database immediately and appears in the list below.</div>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="section-card rounded-4 p-3 p-lg-4">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                        <h3 class="h6 mb-0 text-uppercase text-body-secondary letter-spaced">Saved fields</h3>
                        <span class="small text-body-secondary">@Model.Document.SignatureFields.Count total</span>
                    </div>

                    @if (Model.Document.SignatureFields.Count == 0)
                    {
                        <p id="signatureFieldEmptyState" class="text-body-secondary mb-0">No signature fields are stored for this document yet.</p>
                    }
                    else
                    {
                        <p id="signatureFieldEmptyState" class="text-body-secondary mb-3 d-none">No signature fields are stored for this document yet.</p>
                    }

                    <div id="signatureFieldRows" class="field-list d-grid gap-2">
                        @foreach (var field in Model.Document.SignatureFields)
                        {
                            <div class="field-entry rounded-4 p-3" data-field-id="@field.Id">
                                <div class="d-flex align-items-center justify-content-between gap-3">
                                    <div class="d-flex flex-wrap align-items-center gap-2">
                                        <div class="fw-semibold">@field.Label</div>
                                        <span class="badge rounded-pill text-bg-secondary">@(field.IsRequired ? "Required" : "Optional")</span>
                                    </div>
                                    <form method="post"
                                          asp-page-handler="DeleteField"
                                          asp-route-signatureFieldId="@field.Id"
                                          data-delete-field-form="true"
                                          class="ms-auto">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script type="module" src="~/js/document-preview.js" asp-append-version="true"></script>
}

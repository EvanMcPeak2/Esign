@page
@model PdfSigning.Web.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Documents";
}

<div class="row align-items-center mb-4">
    <div class="col-lg-8">
        <span class="badge text-bg-dark mb-2">Protected area</span>
        <h1 class="display-6 fw-semibold mb-2">Documents</h1>
        <p class="text-body-secondary mb-0">Upload a PDF here to start the signing workflow.</p>
    </div>
    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
        <a class="btn btn-primary" href="/">Back to home</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="feature-card rounded-4 p-4 h-100">
            <h2 class="h4 mb-3">Upload a PDF</h2>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="alert @(Model.UploadedFileUrl is null ? "alert-warning" : "alert-success")" role="alert">
                    @Model.StatusMessage
                    @if (Model.UploadedFileUrl is not null)
                    {
                        <div class="mt-2">
                            Saved as <strong>@Model.UploadedFileName</strong>.
                            <a href="@Url.Page("/Documents/Pdf", new { id = Model.UploadedDocumentId })" target="_blank" rel="noopener">Open uploaded file</a>
                            @if (Model.UploadedDocumentId is not null)
                            {
                                <span class="mx-2">|</span>
                                <a href="@Url.Page("/Documents/View", new { id = Model.UploadedDocumentId })">View database record</a>
                            }
                        </div>
                    }
                </div>
            }

            <form method="post" enctype="multipart/form-data" class="upload-form">
                <div class="mb-3">
                    <label asp-for="PdfFile" class="form-label">PDF file</label>
                    <input asp-for="PdfFile" type="file" class="form-control" accept="application/pdf,.pdf" />
                    <div class="form-text text-body-secondary">Choose a PDF file from your computer.</div>
                </div>
                <button type="submit" class="btn btn-primary">Upload PDF</button>
            </form>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="status-panel rounded-4 p-4 h-100">
            <h2 class="h4 mb-3">Recent uploads</h2>
            @if (Model.RecentDocuments.Count == 0)
            {
                <p class="text-body-secondary mb-0">No documents have been uploaded yet.</p>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var doc in Model.RecentDocuments)
                    {
                        <a class="list-group-item list-group-item-action px-0" href="@Url.Page("/Documents/View", new { id = doc.Id })">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@doc.Title</div>
                                    <div class="small text-body-secondary">@doc.OriginalFileName</div>
                                    <div class="small text-body-secondary">@doc.Status · @doc.SignatureFieldCount field(s)</div>
                                </div>
                                <span class="badge text-bg-secondary">@doc.CreatedAtUtc.ToLocalTime().ToString("g")</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

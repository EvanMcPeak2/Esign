<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PdfSigning.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <header class="navbar navbar-expand-lg navbar-dark app-navbar sticky-top border-bottom border-dark-subtle">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="/">PdfSigning</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Documents">Documents</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Privacy">Privacy</a></li>
                </ul>
                <div class="d-flex gap-2 align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="navbar-text text-light-emphasis small d-none d-lg-inline">Signed in</span>
                        <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-outline-light btn-sm">Log out</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm" asp-area="Identity" asp-page="/Account/Login">Log in</a>
                        <a class="btn btn-primary btn-sm" asp-area="Identity" asp-page="/Account/Register">Register</a>
                    }
                </div>
            </div>
        </div>
    </header>
    <main class="container py-4 py-lg-5">
        @RenderBody()
    </main>
    <footer class="border-top border-dark-subtle py-4">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-2 small text-body-secondary">
            <span>&copy; 2026 - PdfSigning.Web</span>
            <span>Browser-based PDF signing</span>
        </div>
    </footer>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
